        "\n",
        "        preds = model(ctx_t, ctx_v, ctx_mask, tgt_t)  #(batch, MAX_TARGET)\n",
        "\n",
        "\n",
        "        preds_cpu = preds.cpu().numpy()\n",
        "        mask_np   = tgt_mask.numpy()\n",
        "\n",
        "        for i in range(len(batch['sample_id'])):\n",
        "            sid       = batch['sample_id'][i]\n",
        "            t_min     = batch['t_min'][i].item()\n",
