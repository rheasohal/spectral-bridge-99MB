    {
      "cell_type": "code",
      "source": [
        "#Building a PyTorch Dataset\n",
        "#What this does:\n",
        "#For each of the 80,000 audio clips (Sample_IDs) we:\n",
        "#   -Find the \"context\" rows (Is_Context == 1) — the KNOWN signal\n",
        "#   -Find the \"target\" rows  (Is_Context == 0) — the MISSING signal we must predict\n",
        "#\n",
        "#We pack these into fixed-size arrays so the GPU can process them in batches.\n",
        "\n",
        "MAX_CONTEXT = 50\n",
        "MAX_TARGET  = 60\n",
        "\n",
        "class AudioInpaintDataset(Dataset):\n",
        "    def __init__(self, df, is_train=True):\n",
        "        self.samples = []\n",
        "\n",
        "        print(\"Grouping by Sample_ID...\")\n",
        "        grouped = df.groupby('Sample_ID')\n",
        "\n",
        "        for sample_id, group in grouped:\n",
        "            context = group[group['Is_Context'] == 1].sort_values('Time_ms')\n",
        "            target  = group[group['Is_Context'] == 0].sort_values('Time_ms')\n",
        "\n",
        "            if len(context) < 2 or len(target) < 1:\n",
        "                continue\n",
        "\n",
        "            #Normalizing Time_ms to [0, 1]\n",
        "            t_min, t_max = group['Time_ms'].min(), group['Time_ms'].max()\n",
        "            t_range = max(t_max - t_min, 1.0)\n",
        "\n",
        "            ctx_t = ((context['Time_ms'].values - t_min) / t_range).astype(np.float32)\n",
        "            ctx_v = context['Value'].values.astype(np.float32)\n",
        "            tgt_t = ((target['Time_ms'].values  - t_min) / t_range).astype(np.float32)\n",
        "            tgt_v = target['Value'].values.astype(np.float32)  #Ground truth value\n",
        "\n",
        "            self.samples.append({\n",
        "                'sample_id': sample_id,\n",
        "                'ctx_t': ctx_t,\n",
        "                'ctx_v': ctx_v,\n",
        "                'tgt_t': tgt_t,\n",
        "                'tgt_v': tgt_v,\n",
        "                't_min': t_min,\n",
        "                't_range': t_range,\n",
        "            })\n",
        "\n",
        "        print(f\"Dataset built: {len(self.samples):,} valid samples\")\n",
        "\n",
        "    def __len__(self):\n",
        "        return len(self.samples)\n",
        "\n",
        "    def __getitem__(self, idx):\n",
        "        s = self.samples[idx]\n",
        "\n",
        "        #Pading or trimming context to MAX_CONTEXT length\n",
        "        n_ctx = min(len(s['ctx_t']), MAX_CONTEXT)\n",
        "        ctx_t = np.zeros(MAX_CONTEXT, dtype=np.float32)\n",
        "        ctx_v = np.zeros(MAX_CONTEXT, dtype=np.float32)\n",
        "        ctx_mask = np.zeros(MAX_CONTEXT, dtype=np.float32)\n",
        "        ctx_t[:n_ctx] = s['ctx_t'][:n_ctx]\n",
        "        ctx_v[:n_ctx] = s['ctx_v'][:n_ctx]\n",
        "        ctx_mask[:n_ctx] = 1.0  #1 = real data, 0 = padding\n",
        "\n",
        "        #Padding or trimming targets to MAX_TARGET length\n",
        "        n_tgt = min(len(s['tgt_t']), MAX_TARGET)\n",
        "        tgt_t = np.zeros(MAX_TARGET, dtype=np.float32)\n",
        "        tgt_v = np.zeros(MAX_TARGET, dtype=np.float32)\n",
        "        tgt_mask = np.zeros(MAX_TARGET, dtype=np.float32)\n",
        "        tgt_t[:n_tgt] = s['tgt_t'][:n_tgt]\n",
        "        tgt_v[:n_tgt] = s['tgt_v'][:n_tgt]\n",
        "        tgt_mask[:n_tgt] = 1.0\n",
        "\n",
        "        return {\n",
        "            'ctx_t':    torch.FloatTensor(ctx_t),\n",
        "            'ctx_v':    torch.FloatTensor(ctx_v),\n",
        "            'ctx_mask': torch.FloatTensor(ctx_mask),\n",
        "            'tgt_t':    torch.FloatTensor(tgt_t),\n",
        "            'tgt_v':    torch.FloatTensor(tgt_v),   #Ground truth value\n",
        "            'tgt_mask': torch.FloatTensor(tgt_mask),\n",
        "            'sample_id': s['sample_id'],\n",
        "            't_min':    s['t_min'],\n",
        "            't_range':  s['t_range'],\n",
        "        }\n",
        "\n",
        "dataset = AudioInpaintDataset(df)"
      ],
