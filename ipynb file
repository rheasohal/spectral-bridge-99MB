      "cell_type": "code",
      "source": [
        "#The Neural Process Transformer\n",
        "#HOW IT WORKS:\n",
        "#\n",
        "#Step 1 — ENCODE CONTEXT:\n",
        "#   Each context point is (time, value). We embed both into a 64-dim vector.\n",
        "#   A Transformer encoder lets every context point \"look at\" every other one.\n",
        "#   This builds a rich understanding of \"what kind of audio is this clip?\"\n",
        "#\n",
        "#Step 2 — DECODE TARGETS:\n",
        "#   For each missing target time, we ask: given all the context I've seen,\n",
        "#   what value should be here?\n",
        "#   A cross-attention decoder attends to the encoded context to answer this.\n",
        "#\n",
        "#This all happens in ONE forward pass without\n",
        "\n",
        "class AudioTransformerNP(nn.Module):\n",
        "    def __init__(self, d_model=64, nhead=4, num_encoder_layers=3, num_decoder_layers=3):\n",
        "        super().__init__()\n",
        "\n",
        "        #Embed a single (time, value) pair into d_model dimensions\n",
        "        self.ctx_embed = nn.Sequential(\n",
        "            nn.Linear(2, d_model),\n",
        "            nn.ReLU(),\n",
        "            nn.Linear(d_model, d_model)\n",
        "        )\n",
        "\n",
        "        #Embed a single target time into d_model dimensions\n",
        "        self.tgt_embed = nn.Sequential(\n",
        "            nn.Linear(1, d_model),\n",
        "            nn.ReLU(),\n",
        "            nn.Linear(d_model, d_model)\n",
        "        )\n",
        "\n",
        "        #Transformer encoder: context points attend to each other\n",
        "        encoder_layer = nn.TransformerEncoderLayer(\n",
        "            d_model=d_model, nhead=nhead, dim_feedforward=256,\n",
        "            dropout=0.1, batch_first=True\n",
        "        )\n",
        "        self.encoder = nn.TransformerEncoder(encoder_layer, num_layers=num_encoder_layers)\n",
        "\n",
        "        #Transformer decoder: target queries attend to encoded context\n",
        "        decoder_layer = nn.TransformerDecoderLayer(\n",
        "            d_model=d_model, nhead=nhead, dim_feedforward=256,\n",
        "            dropout=0.1, batch_first=True\n",
        "        )\n",
        "        self.decoder = nn.TransformerDecoder(decoder_layer, num_layers=num_decoder_layers)\n",
        "\n",
        "        #Final prediction head: d_model → 1 predicted value\n",
        "        self.output_head = nn.Linear(d_model, 1)\n",
        "\n",
        "    def forward(self, ctx_t, ctx_v, ctx_mask, tgt_t):\n",
        "        \"\"\"\n",
        "        ctx_t:    (batch, MAX_CONTEXT)     — context times\n",
        "        ctx_v:    (batch, MAX_CONTEXT)     — context values\n",
        "        ctx_mask: (batch, MAX_CONTEXT)     — 1=real, 0=padding\n",
        "        tgt_t:    (batch, MAX_TARGET)      — target times to predict\n",
        "        Returns:  (batch, MAX_TARGET)      — predicted values\n",
        "        \"\"\"\n",
        "        B = ctx_t.shape[0]\n",
        "\n",
        "        #Stack time and value: (batch, MAX_CONTEXT, 2)\n",
        "        ctx_input = torch.stack([ctx_t, ctx_v], dim=-1)\n",
        "\n",
        "        #Embed context: (batch, MAX_CONTEXT, d_model)\n",
        "        ctx_emb = self.ctx_embed(ctx_input)\n",
        "\n",
        "        #Embed target times: (batch, MAX_TARGET, d_model)\n",
        "        tgt_input = tgt_t.unsqueeze(-1)  #(batch, MAX_TARGET, 1)\n",
        "        tgt_emb = self.tgt_embed(tgt_input)\n",
        "\n",
        "        #Build padding mask for encoder (True = ignore this position)\n",
        "        ctx_key_padding_mask = (ctx_mask == 0)  #(batch, MAX_CONTEXT)\n",
        "\n",
        "        #Encode context\n",
        "        memory = self.encoder(ctx_emb, src_key_padding_mask=ctx_key_padding_mask)\n",
        "\n",
        "        #Decode: target queries cross-attend to encoded context\n",
        "        decoded = self.decoder(tgt_emb, memory, memory_key_padding_mask=ctx_key_padding_mask)\n",
        "\n",
        "        #Predict values: (batch, MAX_TARGET, 1) → (batch, MAX_TARGET)\n",
        "        predictions = self.output_head(decoded).squeeze(-1)\n",
        "\n",
        "        return predictions\n",
        "\n",
        "#Create the model and move to GPU\n",
        "model = AudioTransformerNP(d_model=64, nhead=4, num_encoder_layers=3, num_decoder_layers=3)\n",
        "model = model.to(device)\n",
        "\n",
        "#Count parameters\n",
        "total_params = sum(p.numel() for p in model.parameters())\n",
        "print(f\"Model created! Total parameters: {total_params:,}\")\n",
        "print(f\"Model is on: {next(model.parameters()).device}\")"
      ],
