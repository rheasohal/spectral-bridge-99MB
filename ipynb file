        "#Running inference on the test dataset\n",
        "\n",
        "\n",
        "TEST_PATH = '/content/drive/MyDrive/test_features_spectral.csv'\n",
        "\n",
        "print(\"Loading test data...\")\n",
        "test_df = pd.read_csv(TEST_PATH)\n",
